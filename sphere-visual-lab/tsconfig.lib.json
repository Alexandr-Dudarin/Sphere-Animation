{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "incremental": false,
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "stripInternal": true,
    "rootDir": "./src",
    "outDir": "./dist-lib/types"
  },
  "include": ["src/index.ts"],
  "exclude": [
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/demo",
    "src/app",
    "src/main.tsx"
  ]
}
